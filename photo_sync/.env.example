# ------- Snipe-IT -------
SNIPE_URL=https://snipeit.example.com
SNIPE_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9...

# ------- Azure AD app (client credentials flow) -------
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=replace-me

# ------- OneDrive target -------
# Either a user (UPN or object id) whose OneDrive we upload to:
ONEDRIVE_USER_ID=svc-assets@yourcompany.com
# OR an explicit drive id (leave ONEDRIVE_USER_ID blank if you set this):
# ONEDRIVE_DRIVE_ID=b!xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Top-level folder under the drive root where per-asset folders are created
ONEDRIVE_BASE_FOLDER=AssetPhotos

# ------- Behavior flags -------
# Append OneDrive Backup links to Snipe-IT asset notes after a successful upload
WRITE_BACK_TO_SNIPEIT=false

# Re-upload everything even if it's already in the dedupe DB
FORCE_RESYNC=false

# SQLite file used to track what's been uploaded
DEDUPE_DB_PATH=photo_sync_state.db

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
